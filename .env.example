# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit API keys.

# Required: Anthropic API key for AI-assisted editing
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override where projects are stored (default: ./projects)
# DARKROOM_PROJECTS_DIR=/path/to/your/projects
